{
  "name": "graven---metals",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "nodemon backend/src/server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "start:server": "node backend/src/server.js",
    "start": "node backend/server.js",
    "prod:server": "node backend/server.js",
    "clean": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "tsc && vite build",
    "build:frontend": "npm run clean && npm run build && node scripts/compress-assets.mjs",
    "build:vercel": "npm run env:check:frontend && npm run build:frontend",
    "build:backend": "npm --prefix backend ci --omit=dev",
    "build:production": "npm run build:frontend",
    "env:check:frontend": "node scripts/check-frontend-env.mjs",
    "env:check:production": "node scripts/check-production-env.mjs",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.13",
    "typescript": "~6.0.2",
    "vite": "^4.5.5"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "framer-motion": "^11.11.17",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.28.1"
  }
}
